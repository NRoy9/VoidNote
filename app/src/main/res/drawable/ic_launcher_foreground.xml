<!--
    ic_launcher_foreground.xml

    The foreground layer of the Void Note adaptive icon.
    This is the document logo: folded-corner page + text lines + void circle.

    HOW ADAPTIVE ICONS WORK:
    Android uses TWO layers — foreground (this file) + background (ic_launcher_background.xml).
    The device clips them into its preferred shape (circle, squircle, etc).
    Keep all important content inside the center 72x72dp "safe zone" of the 108x108 canvas.
    That's why we offset everything by +6 from the original 96x96 SVG design.

    VIEWPORT: 108x108 is the Android standard for adaptive icon foregrounds.
    SAFE ZONE: Center 72x72 (from x=18,y=18 to x=90,y=90). Our content sits comfortably inside.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
  <group android:scaleX="0.9"
      android:scaleY="0.9"
      android:translateX="5.4"
      android:translateY="4.95">
    <group android:scaleX="0.99"
        android:scaleY="0.99"
        android:translateX="0.045"
        android:translateY="0.54">
      <group android:scaleX="0.80347824"
          android:scaleY="0.80347824"
          android:translateX="15.834783"
          android:translateY="15.031304">

          <!--
              DOCUMENT OUTLINE — the notched rectangle shape.

              This is NOT a simple rect because the top-right corner is "cut"
              for the fold effect. So we draw it as a single path going clockwise:
              top-left → fold-start → fold-end (diagonal) → bottom-right → bottom-left → top-left

              Q = quadratic bezier curve (used for the rounded corners, rx=3 equivalent)
              L = straight line
              M = move to (start point)
              Z = close path

              strokeColor white (#FFFFFF), no fill — matches the website logo exactly.
          -->
          <path
              android:pathData="
                  M 25,16
                  L 58,16
                  L 74,32
                  L 74,79
                  Q 74,82 71,82
                  L 25,82
                  Q 22,82 22,79
                  L 22,19
                  Q 22,16 25,16
                  Z"
              android:strokeWidth="2.5"
              android:strokeColor="#FFFFFF"
              android:fillColor="@android:color/transparent"
              android:strokeLineCap="round"
              android:strokeLineJoin="round"/>

          <!--
              RED FOLD CREASE — the L-shaped line at the top-right corner.

              This is the "dog-ear" fold. Two lines forming an L:
              - Vertical line down from fold start (58,16) to (58,32)
              - Horizontal line right from (58,32) to fold end (74,32)

              Uses VoidAccent red #FF3B30 — matches Color.kt in the Android app exactly.
          -->
          <path
              android:pathData="M 58,16 L 58,32 L 74,32"
              android:strokeWidth="2.5"
              android:strokeColor="#FF3B30"
              android:fillColor="@android:color/transparent"
              android:strokeLineCap="round"
              android:strokeLineJoin="round"/>

          <!--
              TEXT LINES — three horizontal lines representing note content.
              Third line is shorter (stops at x=48) — looks like a real paragraph ending.
              strokeLineCap="round" softens the line ends subtly.
          -->
          <path
              android:pathData="M 30,44 L 60,44"
              android:strokeWidth="2"
              android:strokeColor="#FFFFFF"
              android:fillColor="@android:color/transparent"
              android:strokeLineCap="round"/>

          <path
              android:pathData="M 30,53 L 60,53"
              android:strokeWidth="2"
              android:strokeColor="#FFFFFF"
              android:fillColor="@android:color/transparent"
              android:strokeLineCap="round"/>

          <path
              android:pathData="M 30,62 L 48,62"
              android:strokeWidth="2"
              android:strokeColor="#FFFFFF"
              android:fillColor="@android:color/transparent"
              android:strokeLineCap="round"/>

          <!--
              VOID CIRCLE — the ○ brand signature.
              Sits bottom-right inside the document. "The void is inside the note."

              A circle in SVG path format:
              M = move to leftmost point of circle (cx - r = 60 - 7 = 53)
              A = arc: rx=7, ry=7, x-rotation=0, large-arc=1, sweep=0, end point
              Two arcs needed to complete a full circle (SVG limitation).

              Red #FF3B30 — same accent as the fold, ties both elements together.
          -->
          <path
              android:pathData="M 53,66 A 7,7 0 1 0 67,66 A 7,7 0 1 0 53,66 Z"
              android:strokeWidth="2"
              android:strokeColor="#FF3B30"
              android:fillColor="@android:color/transparent"/>

      </group>
    </group>
  </group>
</vector>